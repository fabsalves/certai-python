# Copie para .env e ajuste. NUNCA versione o .env real.

# App
ENV=dev
DEBUG=true

# Segurança — gere uma chave forte: openssl rand -hex 32
SECRET_KEY=troque-por-uma-chave-aleatoria-de-pelo-menos-32-caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost:5173

# Banco
POSTGRES_USER=certai
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=certai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# IA (OpenAI — motor, humanizador, avaliador; alinhado ao Realtime)
OPENAI_API_KEY=
ENGINE_MODEL=gpt-4o
HUMANIZER_MODEL=gpt-4o-mini
EVALUATOR_MODEL=gpt-4o
GROQ_API_KEY=
GROQ_TRANSCRIBE_MODEL=whisper-large-v3

# OpenAI Realtime (voz ao vivo — /voz/:token)
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=coral
OPENAI_REALTIME_REASONING_EFFORT=low
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_TRANSCRIPTION_LANGUAGE=pt
# VAD: server_vad; ajuste threshold/padding/silence via ENV se necessário.
# semantic_vad + low realimentava eco do alto-falante como fala fantasma — só p/ experimentos.
OPENAI_REALTIME_TURN_DETECTION=server_vad
OPENAI_REALTIME_INTERRUPT_RESPONSE=true
OPENAI_REALTIME_VAD_THRESHOLD=0.9
OPENAI_REALTIME_VAD_PREFIX_PADDING_MS=500
OPENAI_REALTIME_VAD_SILENCE_DURATION_MS=1200
# Só com semantic_vad: OPENAI_REALTIME_VAD_EAGERNESS=low

# Storage — local em dev; s3 em staging/prod
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./media
AWS_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cinndi / WhatsApp — preencha no .env local (nunca commite valores reais)
CINNDI_API_URL=https://api.cinndi.com/v2
CINNDI_API_KEY=
CINNDI_SENDER_PHONE=5511999999999
CINNDI_WEBHOOK_TOKEN=
CINNDI_INSECURE_SSL=false
WHATSAPP_INVITE_TEMPLATE=certai_convite_aula
WHATSAPP_INVITE_VOICE_TEMPLATE=certai_convite_aula_voz_v2
# true = template com botão URL (v2); false = certai_convite_aula (texto only)
WHATSAPP_INVITE_USE_VOICE_TEMPLATE=false
WHATSAPP_TEMPLATE_LANG=pt_BR
ASSISTANT_NAME=Lira
INBOUND_DEBOUNCE_SECONDS=5

# Voz / handoff (rota pública /voz/:token)
# Dev local (voice-link): http://localhost:5173
# Teste mobile (cloudflared): use a URL HTTPS do túnel — ver docs/voice-mobile-dev-tunnel.md
# Prod/staging (botão WhatsApp v2): https://app.certai.com.br — deve bater com botoesURL.url do template
FRONTEND_BASE_URL=http://localhost:5173
VOICE_HANDOFF_EXPIRE_HOURS=48
