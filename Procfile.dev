api: cd backend && . .venv/bin/activate && uvicorn app.main:app --reload --host 0.0.0.0 --port ${API_PORT:-8000}
worker: cd backend && . .venv/bin/activate && celery -A app.workers.celery_app.celery_app worker -n certai-dev@%h -Q default,transcricao,disparo,avaliacao --concurrency=4 -l info
beat: cd backend && . .venv/bin/activate && celery -A app.workers.celery_app.celery_app beat -l info
flower: cd backend && . .venv/bin/activate && celery -A app.workers.celery_app.celery_app flower --port=${FLOWER_PORT:-5555}
frontend: cd frontend && API_PORT=${API_PORT:-8000} FRONTEND_PORT=${FRONTEND_PORT:-5173} npm run dev
